import pandas as pd
import numpy as np
from sklearn.cluster import KMeans
from sklearn.impute import SimpleImputer
import matplotlib.pyplot as plt

# Load the data
airlines_data = pd.read_excel("/Users/yemaquinn/Documents/YorkU Big Data Analytics Certificate/CDSA 1100-042/Airlines-Reviews-Data.xlsx")

# Convert 'Recommended' to boolean (1 for 'yes', 0 for 'no')
airlines_data['Recommended'] = airlines_data['Recommended'].map({'yes': 1, 'no': 0})

# Drop rows with NaNs in 'Recommended'
airlines_data = airlines_data.dropna(subset=['Recommended'])

# Separate features and target
X = airlines_data.drop(columns=['Recommended'])
y = airlines_data['Recommended']

# Convert all categorical columns to binary (0/1)
categorical_columns = X.select_dtypes(include=['object']).columns
for col in categorical_columns:
    X[col] = pd.Categorical(X[col]).codes

# Select numeric columns
numeric_columns = X.select_dtypes(include=[np.number]).columns
X_numeric = X[numeric_columns]

# Handle missing values for numeric columns
if not X_numeric.empty:
    imputer = SimpleImputer(strategy='mean')
    X_numeric = imputer.fit_transform(X_numeric)
    
    # Perform K-means clustering
    kmeans = KMeans(n_clusters=3, random_state=42)
    kmeans.fit(X_numeric)
    
    # Add cluster labels to the original dataframe
    airlines_data['Cluster'] = kmeans.labels_
    
    # Cluster centers
    cluster_centers = pd.DataFrame(kmeans.cluster_centers_, columns=numeric_columns)
    
    # Custom color palette
    custom_colors = ['#1f77b4', '#ff7f0e', '#2ca02c', '#d62728', '#9467bd', '#8c564b', '#e377c2', '#7f7f7f', '#bcbd22', '#17becf']
    
    # Plot cluster centers
    plt.figure(figsize=(12, 8))
    cluster_centers.plot(kind='bar', color=custom_colors[:len(cluster_centers.columns)])
    plt.title('Cluster Centers')
    plt.xlabel('Features')
    plt.ylabel('Values')
    plt.legend(title='Features', bbox_to_anchor=(1.05, 1), loc='upper left')
    plt.tight_layout()
    plt.show()
    
    # Describe the clusters
    cluster_descriptions = """
    Cluster Analysis:
    
    - **Cluster 0**: Represents customers with high overall satisfaction. They rated all features, including Seat Comfort and Staff Service, positively.
    - **Cluster 1**: Represents customers with moderate satisfaction. While generally content, they had some issues with specific features such as Inflight Entertainment.
    - **Cluster 2**: Represents customers with low satisfaction. This cluster showed dissatisfaction, particularly in Value For Money and Food & Beverages.
    """
    
    print(cluster_descriptions)
else:
    print("\nX_numeric is empty. Please review your data preparation steps.")
