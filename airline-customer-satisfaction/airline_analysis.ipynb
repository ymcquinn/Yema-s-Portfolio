import pandas as pd
import numpy as np
from sklearn.impute import SimpleImputer
from sklearn.cluster import KMeans
import matplotlib.pyplot as plt

# Load the data
airlines_data = pd.read_excel("/Users/yemaquinn/Documents/YorkU Big Data Analytics Certificate/CDSA 1100-042/Airlines-Reviews-Data.xlsx")

# Convert 'Recommended' to boolean (1 for 'yes', 0 for 'no')
airlines_data['Recommended'] = airlines_data['Recommended'].map({'yes': 1, 'no': 0})

# Drop rows with NaNs in 'Recommended'
airlines_data = airlines_data.dropna(subset=['Recommended'])

# Convert 'Type of Traveller' to categorical codes
airlines_data['Type of Traveller'] = pd.Categorical(airlines_data['Type of Traveller']).codes

# Separate features and target
X = airlines_data.drop(columns=['Recommended'])
y = airlines_data['Recommended']

# Convert all categorical columns to binary (0/1)
categorical_columns = X.select_dtypes(include=['object']).columns
for col in categorical_columns:
    X[col] = pd.Categorical(X[col]).codes

# Ensure all columns in X are numeric
print("\nData types after conversion:")
print(X.dtypes)

# Select numeric columns
X_numeric = X.select_dtypes(include=[np.number])

# Print columns in X_numeric
print("\nColumns in X_numeric:")
print(X_numeric.columns)

# Check the shape and content of X_numeric
print("\nShape of X_numeric after selecting numeric columns:", X_numeric.shape)
print(X_numeric.head())

# Handle missing values for numeric columns
if not X_numeric.empty:
    imputer = SimpleImputer(strategy='mean')
    X_numeric = imputer.fit_transform(X_numeric)
    
    # Ensure X_numeric and y have the same length
    assert len(X_numeric) == len(y), "Mismatch between X_numeric and y lengths"
    
    print("\nX_numeric after imputation:")
    print(X_numeric)
else:
    print("\nX_numeric is empty. Please review your data preparation steps.")

# Fit KMeans
kmeans = KMeans(n_clusters=3, random_state=42)  # Adjust n_clusters as needed
clusters = kmeans.fit_predict(X_numeric)

# Add the cluster labels to the original DataFrame
airlines_data['Cluster'] = clusters

# Cross-tabulation of clusters vs. 'Type of Traveller'
cluster_traveller_crosstab = pd.crosstab(airlines_data['Cluster'], airlines_data['Type of Traveller'])

print("\nCross-tabulation of clusters vs. 'Type of Traveller':")
print(cluster_traveller_crosstab)

# Plot the distribution of 'Type of Traveller' within each cluster
plt.figure(figsize=(10, 6))
airlines_data.groupby(['Cluster', 'Type of Traveller']).size().unstack().plot(kind='bar', stacked=True, colormap='viridis')

plt.title('Distribution of Type of Traveller Across Clusters')
plt.xlabel('Cluster')
plt.ylabel('Number of Reviews')
plt.legend(title='Type of Traveller')
plt.show()

# Calculate correlation between clusters and 'Type of Traveller'
correlation = airlines_data[['Cluster', 'Type of Traveller']].corr()
print("\nCorrelation between clusters and 'Type of Traveller':")
print(correlation)
